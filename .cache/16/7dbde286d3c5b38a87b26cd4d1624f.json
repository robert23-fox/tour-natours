ginal":{"line":45,"column":41}},{"generated":{"line":63,"column":22},"source":"leafletjs.js","original":{"line":45,"column":44}},{"generated":{"line":64,"column":2},"source":"leafletjs.js","original":{"line":45,"column":46}},{"generated":{"line":64,"column":3},"source":"leafletjs.js","original":{"line":45,"column":47}},{"generated":{"line":64,"column":4},"source":"leafletjs.js","original":{"line":45,"column":48}},{"generated":{"line":65,"column":0},"source":"leafletjs.js","original":{"line":46,"column":0}},{"generated":{"line":65,"column":1},"source":"leafletjs.js","original":{"line":46,"column":1}}],"sources":{"leafletjs.js":"/*eslint-disable*/\r\n\r\nexport const displayMap = (locations) => {\r\n  if (typeof L === \"undefined\") {\r\n    console.error(\"Leaflet.js is not loaded.\");\r\n    return;\r\n  }\r\n\r\n  // Custom Icon configuration\r\n  const customIcon = L.icon({\r\n    iconUrl: \"/img/pin.png\", // Custom icon path\r\n    iconSize: [32, 40], // Width, Height\r\n    iconAnchor: [16, 40], // Anchor point of the icon\r\n    popupAnchor: [0, -40], // Popup position relative to the icon\r\n  });\r\n\r\n  // Initialize the map\r\n  const map = L.map(\"map\", { zoomControl: false }).setView(\r\n    [locations[0].coordinates[1], locations[0].coordinates[0]], // Latitude, Longitude\r\n    8 // Zoom level (increased for more detail)\r\n  );\r\n\r\n  // Add CartoDB Light tile layer to the map\r\n  L.tileLayer(\"https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png\", {\r\n    attribution:\r\n      '&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors',\r\n    maxZoom: 19,\r\n  }).addTo(map);\r\n\r\n  // Add custom markers for each location\r\n  locations.forEach((loc) => {\r\n    const [lng, lat] = loc.coordinates; // Destructure coordinates\r\n\r\n    L.marker([lat, lng], { icon: customIcon })\r\n      .addTo(map)\r\n      .bindPopup(`<b>Day ${loc.day}:</b> ${loc.description}`) // Popup content\r\n      .openPopup();\r\n  });\r\n\r\n  // Automatically fit bounds to markers with some padding\r\n  const bounds = locations.map((loc) => [\r\n    loc.coordinates[1],\r\n    loc.coordinates[0],\r\n  ]);\r\n  map.fitBounds(bounds, { padding: [100, 100] });\r\n};\r\n"},"lineCount":null}},"error":null,"hash":"8eeb7d6f9d9735b8275bcdbd64a7a315","cacheData":{"env":{}}}